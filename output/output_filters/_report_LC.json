{
  "multiple": [
      {
          "name": "% L1",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_1",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "horizontal_aggregation": "division",
          "vertical_aggregation": "average",
          "horizontal_first": "true",
          "horizontal_order": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_1",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "slice_start": -365
         },
         {
          "name": "% L2",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_2",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "horizontal_aggregation": "division",
          "vertical_aggregation": "average",
          "horizontal_first": "true",
          "horizontal_order": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_2",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "slice_start": -365
         },
         {
          "name": "% L3",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_3",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "horizontal_aggregation": "division",
          "vertical_aggregation": "average",
          "horizontal_first": "true",
          "horizontal_order": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_3",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "slice_start": -365
         },
         {
          "name": "% L4+",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_greater_than_3",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "horizontal_aggregation": "division",
          "vertical_aggregation": "average",
          "horizontal_first": "true",
          "horizontal_order": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_greater_than_3",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "slice_start": -365
      },
      {
          "name": "Calf enteric methane, g",
          "filters": [
              "AnimalModuleReporter.report_animal_module_manure.daily_aggregate_calf_enteric_methane_g"
          ],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Heifer enteric methane, g",
          "filters": [
              "AnimalModuleReporter.report_animal_module_manure.daily_aggregate_heifer_enteric_methane_g"
          ],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Dry cow enteric methane, g",
          "filters": [
              "AnimalModuleReporter.report_animal_module_manure.daily_aggregate_dry_cow_enteric_methane_g"
          ],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Lact cow enteric methane, g",
          "filters": [
              "AnimalModuleReporter.report_animal_module_manure.daily_aggregate_lactating_cow_enteric_methane_g"
          ],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Lact cow enteric methane, kg",
          "cross_references": [
            "Lact cow enteric methane, g_ver_agg"
          ],
          "constants": {
            "by 0.001": 0.001 
          },
          "horizontal_aggregation": "product"
      },
      {
          "name": "Lact cow enteric methane CO2eq, kg",
          "cross_references": [
            "Lact cow enteric methane, g_ver_agg"
          ],
          "constants": {
            "CH4 GWP": 27.2,
            "by 0.001": 0.001 
          },
          "horizontal_aggregation": "product"
      },
      {
          "name": "Total enteric methane, g",
          "filters": [
              "AnimalModuleReporter.report_animal_module_manure.daily_aggregate_(calf|heifer|dry_cow|lactating_cow)_enteric_methane_g"
          ],
          "vertical_aggregation": "sum",
          "horizontal_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Total enteric methane, kg",
          "cross_references": [
            "Total enteric methane, g_hor_ver_agg"
          ],
          "constants": {
            "by 0.001": 0.001 
          },
          "horizontal_aggregation": "product"
      },
      {
          "name": "Total enteric methane CO2eq, kg",
          "cross_references": [
            "Total enteric methane, g_hor_ver_agg"
          ],
          "constants": {
            "CH4 GWP": 27.2,
            "by 0.001": 0.001 
          },
          "horizontal_aggregation": "product"
      },
      {
          "name": "Lact cow purchased feed emissions, kg",
          "filters": [
              "AnimalModuleReporter.report_daily_feed_emissions.pen_.*_animal_LAC_COW_feed_emissions"
          ],
          "variables": ["feed_emissions_total"],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Total purchased feed emissions, kg",
          "filters": [
              "AnimalModuleReporter.report_daily_feed_emissions.*"
          ],
          "variables": ["feed_emissions_total"],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Milking cows",
          "filters": ["AnimalModuleReporter.report_life_cycle_manager_data.milking_cow_num"],
          "vertical_aggregation": "average",
          "slice_start": -365
      },
      {
        "name": "Total milk, kg",
        "filters": ["AnimalModuleReporter.report_life_cycle_manager_data.daily_milk_production"],
        "vertical_aggregation": "sum",
        "slice_start": -365
       },
       {
        "name": "Milk per cow/d, kg",
        "filters": [
            "AnimalModuleReporter.report_life_cycle_manager_data.daily_milk_production",
            "AnimalModuleReporter.report_life_cycle_manager_data.milking_cow_num"
        ],
        "horizontal_aggregation": "division",
        "horizontal_order": [
            "AnimalModuleReporter.report_life_cycle_manager_data.daily_milk_production",
            "AnimalModuleReporter.report_life_cycle_manager_data.milking_cow_num"
        ],
        "horizontal_first": "true",
        "vertical_aggregation": "average",
        "slice_start": -365
       },
       {
        "name": "% milk fat",
        "filters": ["AnimalModuleReporter.report_life_cycle_manager_data.herd_milk_fat_percent"],
        "constants": {
            "By 100": 100
        },
        "vertical_aggregation": "average",
        "horizontal_aggregation": "division",
        "slice_start": -365
    },
    {
        "name": "% milk protein",
        "filters": ["AnimalModuleReporter.report_life_cycle_manager_data.herd_milk_protein_percent"],
        "constants": {
            "By 100": 100
        },
        "vertical_aggregation": "average",
        "horizontal_aggregation": "division",
        "slice_start": -365
    },
    {
        "name": "Milk fat, kg",
        "cross_references": [
            "Total milk, kg_ver_agg",
            "% milk fat_hor_ver_agg"
        ],
        "horizontal_aggregation": "product"
    },
    {
        "name": "Milk protein, kg",
        "cross_references": [
            "Total milk, kg_ver_agg",
            "% milk protein_hor_ver_agg"
        ],
        "horizontal_aggregation": "product"
    },
    {
        "name": "weighted fat value ECM",
        "cross_references": [
            "Milk fat, kg_hor_agg"
        ],
        "constants": {
            "fat weight": 12.30
        },
        "horizontal_aggregation": "product"
    },
    {
        "name": "weighted fat value FPCM",
        "cross_references": [
            "Milk fat, kg_hor_agg"
        ],
        "constants": {
            "fat weight": 12.95
        },
        "horizontal_aggregation": "product"
    },
    {
        "name": "weighted protein value ECM",
        "cross_references": [
            "Milk protein, kg_hor_agg"
        ],
        "constants": {
            "protein weight": 7.77
        },
        "horizontal_aggregation": "product"
    },
    {
        "name": "weighted protein value FPCM",
        "cross_references": [
            "Milk protein, kg_hor_agg"
        ],
        "constants": {
            "protein weight": 7.2
        },
        "horizontal_aggregation": "product"
    },
    {
        "name": "weighted milk value ECM",
        "cross_references": [
            "Total milk, kg_ver_agg"
        ],
        "constants": {
            "milk weight": 0.252
        },
        "horizontal_aggregation": "product"
    },
    {
        "name": "weighted milk value FPCM",
        "cross_references": [
            "Total milk, kg_ver_agg"
        ],
        "constants": {
            "milk weight": 0.327
        },
        "horizontal_aggregation": "product"
    },
    {
        "name": "Herd FPCM, kg",
        "cross_references": [
            "weighted fat value FPCM_hor_agg",
            "weighted protein value FPCM_hor_agg",
            "weighted milk value FPCM_hor_agg"
        ],
        "horizontal_aggregation": "sum"
    },
    {
        "name": "Herd ECM, kg",
        "cross_references": [
            "weighted fat value ECM_hor_agg",
            "weighted protein value ECM_hor_agg",
            "weighted milk value ECM_hor_agg"
        ],
        "horizontal_aggregation": "sum"
    },
    {
        "name": "Cow FPCM/d, kg",
        "cross_references":[
            "Herd FPCM, kg_hor_agg",
            "Milking cows_ver_agg"
        ],
        "constants": {
            "Days per year": 365
        },
        "horizontal_aggregation": "division",
        "horizontal_order": [
            "Herd FPCM, kg_hor_agg",
            "Milking cows_ver_agg",
            "Days per year"
        ]
    },
    {
        "name": "Cow ECM/d, kg",
        "cross_references":[
            "Herd ECM, kg_hor_agg",
            "Milking cows_ver_agg"
        ],
        "constants": {
            "Days per year": 365
        },
        "horizontal_aggregation": "division",
        "horizontal_order": [
            "Herd ECM, kg_hor_agg",
            "Milking cows_ver_agg",
            "Days per year"
        ]
    },
    {
        "name": "Lact cow DMI, kg",
        "filters": [
            "AnimalModuleReporter.report_daily_ration.ration_daily_feed_totals_for_pen_.*_LAC_COW"
        ],
        "variables": ["dry_matter_intake_total"],
        "vertical_aggregation": "sum",
        "slice_start": -365
    },
    {
        "name": "Feed efficiency",
        "cross_references": [
          "Herd ECM, kg_hor_agg",
          "Lact cow DMI, kg_dry_matter_intake_total_ver_agg"
        ],
        "horizontal_aggregation": "division",
        "slice_start": -365
    },
    {
        "name": "Total herd DMI, kg",
        "filters": [
            "^AnimalModuleReporter.report_daily_ration.*"
        ],
        "variables": ["dry_matter_intake_total"],
        "vertical_aggregation": "sum",
        "slice_start": -365
    },
    {
        "name": "Lact cow Manure N, kg",
        "filters": [
            "AnimalModuleReporter.report_animal_module_manure.daily_aggregate_lactating_cow_manure_nitrogen"
        ],
        "vertical_aggregation": "sum",
        "slice_start": -365
    },
    {
        "name": "Total herd Manure N, kg",
        "filters": [
            "AnimalModuleReporter.report_animal_module_manure.daily_aggregate_(calf|heifer|dry_cow|lactating_cow)_manure_nitrogen"
        ],
        "vertical_aggregation": "sum",
        "slice_start": -365
    },
    {
        "name": "Lact cow degradable volatile solids, kg",
        "filters": [
            "AnimalModuleReporter.report_animal_module_manure.daily_aggregate_lactating_cow_degradable_volatile_solids"
        ],
        "vertical_aggregation": "sum",
        "slice_start": -365
    },
    {
        "name": "Lact cow non degradable volatile solids, kg",
        "filters": [
            "AnimalModuleReporter.report_animal_module_manure.daily_aggregate_lactating_cow_non_degradable_volatile_solids"
        ],
        "vertical_aggregation": "sum",
        "slice_start": -365
    },
    {
        "name": "Total herd degradable volatile solids, kg",
        "filters": [
            "AnimalModuleReporter.report_animal_module_manure.daily_aggregate_(calf|heifer|dry_cow|lactating_cow)_degradable_volatile_solids"
        ],
        "vertical_aggregation": "sum",
        "horizontal_aggregation": "sum",
        "slice_start": -365
    }, 
    {
        "name": "Total herd non degradable volatile solids, kg",
        "filters": [
            "AnimalModuleReporter.report_animal_module_manure.daily_aggregate_(calf|heifer|dry_cow|lactating_cow)_non_degradable_volatile_solids"
        ],
        "vertical_aggregation": "sum",
        "horizontal_aggregation": "sum",
        "slice_start": -365
    }   
 ]
}