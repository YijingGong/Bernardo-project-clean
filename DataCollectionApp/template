        <div class="row columns md:flex">
            <div class='col-12 col-md-12 w-12/12'>
                <div id="json-editor-form"></div>
            </div>
        </div>
        <div class="row columns md:flex">
            <div class='col-12 col-md-12 w-12/12'>
                <h2>JSON Output</h2>
                <p>You can also make changes to the JSON here and set the value in the editor by clicking "Update Form"</p>
                <label for="output-textarea"></label>
                <textarea id='output-textarea' rows="15" style="width: 100%; font-family: monospace;" class='form-control'></textarea>
                <button class='btn btn-primary btn-block' id='setvalue'>Update Form</button>
                <h2>Validation</h2>
                <label for="validate-textarea">This will update whenever the form changes to show validation errors if there are any.</label>
                <br>
                <textarea id='validate-textarea' readonly disabled class='form-control'></textarea>
            </div>
        </div>
    </div>
    <script>
        var mySchema = {
            "title": "Data Collection Schema",
            "type": "array",
            "format": "tabs-top",
            "items": {
                "type": "object",
                "title": "Data Entry",
                // List of available schema goes here
            }
        }
        var data = {}
        var defaultOptions = {
            iconlib: 'fontawesome4',
            object_layout: 'normal',
            schema: mySchema,
            show_errors: 'interaction',
            theme: 'bootstrap4'
        }
        var jsoneditor = null
        var directLink = document.querySelector('#direct-link')
        var head = document.getElementsByTagName('head')[0]
        var iconlibLink = document.querySelector('#iconlib-link')
        var jsonEditorForm = document.querySelector('#json-editor-form')
        var setSchema = document.querySelector('#setschema')
        var setValue = document.querySelector('#setvalue')
        var themeLink = document.querySelector('#theme-link')
        var validateTextarea = document.querySelector('#validate-textarea')
        var aceConfig = {
            mode: 'ace/mode/json',
            selection: false,
            maxLines: Infinity,
            minLines: 5
        }
        var outputTextarea = ace.edit('output-textarea', aceConfig)
        var parseUrl = function() {
            var url = window.location.search
            var queryParamsString = url.substring(1, url.length)
            var queryParams = queryParamsString.split('&')
            if (queryParamsString.length) {
                queryParams.forEach(function(queryParam) {
                    var splittedParam = queryParam.split('=')
                    var param = splittedParam[0]
                    var value = splittedParam[1]
                    if (param === 'data') {
                        try {
                            data = JSON.parse(LZString.decompressFromBase64(value))
                        } catch (reason) {}
                    }
                })
            }
            mergeOptions()
        }
        var mergeOptions = function() {
            data.options = Object.assign(defaultOptions, data.options)
            data.options["show_opt_in"] = true
            data.options["required_by_default"] = true
            refreshUI()
        }
        var refreshUI = function() {
            themeLink.href = './css/bootstrap4.0.0.min.css'
            iconlibLink.href = './css/font-awesome.css'
            initJsoneditor()
        }
        var initJsoneditor = function() {
            if (jsoneditor) {
                jsoneditor.destroy()
            }
            jsoneditor = new window.JSONEditor(jsonEditorForm, data.options)
            jsoneditor.on('change', function() {
                var json = jsoneditor.getValue()
                outputTextarea.setValue(JSON.stringify(json, null, 2))
                var validationErrors = jsoneditor.validate()
                if (validationErrors.length) {
                    schemaIndexesToNames = mapSchemaIndexToPropertyNames(mySchema.items.oneOf)
                    errors = stringifyRelevantErrorObjects(validationErrors, schemaIndexesToNames)
                    validateTextarea.value = errors.join("\n")
                } else {
                    validateTextarea.value = 'valid'
                }
            })
            jsoneditor.options.keep_oneof_values = false
        }
        setValue.addEventListener('click', function() {
            jsoneditor.setValue(JSON.parse(outputTextarea.getValue()))
        })
        document.getElementById('save_results').addEventListener('click', function() {
            var data = jsoneditor.getValue();

            if (Array.isArray(data)) {
                data.forEach((item, index) => {
                    var fileName = item.fileName;

                    const { fileName: _, ...jsonDataToDownload } = item;

                    var jsonData = JSON.stringify(jsonDataToDownload, null, 2);

                    saveJsonFile(jsonData, fileName, 'application/json');
                });
                alert(`${data.length} JSON files have been saved.`);
            } else {
                var jsonData = JSON.stringify(data, null, 2);
                saveJsonFile(jsonData, 'data.json', 'application/json');
                alert("Cannot parse data as an array. Saving all data in a single file instead.");
            }
        });

        function saveJsonFile(content, fileName, contentType) {
            var a = document.createElement("a");
            var file = new Blob([content], {
                type: contentType
            });
            a.href = URL.createObjectURL(file);
            a.download = fileName;
            a.click();
        }
        parseUrl()

        /**
         * Maps the index of a Schema to the name of those properties.
         * @param {array of objects} schema - Array of available input schemas.
         * @returns {object mapping ints to strings} - Object mapping index of a schema to the schema's name.
         */
        function mapSchemaIndexToPropertyNames(schema) {
            var schemaIndexToName = {}

            for (let index = 0; index < schema.length; index++) {
                const name = schema[index].title
                schemaIndexToName[index] = name
            }

            return schemaIndexToName
        }

        /**
         * Filters out irrelevant and duplicative errors, and converts them to user-friendly strings.
         * @param {array of objects} errors - All errors found.
         * @param {object mapping ints to strings} schemaIndexesToNames - Maps schema indexes to propery names.
         * @returns {array of strings} Reduced array of errors stringified to be more human-readable.
         */
        function stringifyRelevantErrorObjects(errors, schemaIndexesToNames) {
            const rootErrorPathPattern = /^root\.(\d+)$/;
            relevantErrors = errors.filter(error => (
                error.message !== "Property must be set" && !error.path.match(rootErrorPathPattern)
            ));

            var errorsInfo = []
            var fileNameErrorsIndices = []
            const errorPathPattern = /^root\.(\d+)\.oneOf\[(\d+)\]\.(.+)$/;
            for (let index = 0; index < relevantErrors.length; index++) {
                error = relevantErrors[index]
                const matches = error.path.match(errorPathPattern);

                const dataEntryIndex = matches[1]
                const schemaIndex = matches[2]
                const schemaName = schemaIndexesToNames[schemaIndex]
                const inputVarName = matches[3]

                const isFileNameError = inputVarName === "fileName"
                const isAlreadyPresentForDataEntry = fileNameErrorsIndices.includes(dataEntryIndex)
                if (isFileNameError && !isAlreadyPresentForDataEntry) {
                    const errorString = `Data Entry ${Number(dataEntryIndex) + 1} has invalid file name: ${error.message}.`
                    errorsInfo.push(errorString)
                    fileNameErrorsIndices.push(dataEntryIndex)
                    continue
                } else if (isFileNameError && isAlreadyPresentForDataEntry) {
                    continue
                }

                const errorString = `Data Entry ${Number(dataEntryIndex) + 1} has invalid value for "${inputVarName}" against "${schemaName}": ${error.message}.`
                errorsInfo.push(errorString)
            }
            return errorsInfo
        }
    </script>
</body>

</html>