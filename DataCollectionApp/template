            <div class='col-3 col-md-3 w-3/12'>
                <h1>RuFaS Data Collection</h1>
            </div>
            <div class='col-7 col-md-7 w-7/12'>                
                <div class="alert alert-info text-center alert-dismissible" role="alert">
                    Start by adding a Data Entry. Once done, click "Save Results" button.
                    Values are <span style="color: blue;">BLUE</span>.
                    When a value is deleted, a placeholder default is shown in <span style="color: grey;">GREY</span>.
                    Placeholders are NOT tracked and will show up blank in the Saved Result.
                </div>    
            </div>
            <div class="col-1 col-md-1 w-1/12">        
                <a class="btn btn-primary text-light" id="save_results" title="When finished collecting data, click on this button to save results.">Save Results</a>
                <div class="dropdown" style="padding: 5px;">
                    <button class="btn btn-primary text-light">User Guide</button>
                    <div class="dropdown-content">
                        <a class="btn" href="https://youtu.be/V8y1OC3oQSA" target="_blank" id="user_guide" rel="noopener noreferrer" title="For additional info or help, click here to open User Guide Instructional Video.">User Guide Video</a>
                        <a class="btn" href="https://youtu.be/avFdNwD5S_Q" target="_blank" id="user_guide" rel="noopener noreferrer" title="For additional info or help, click here to open Crop Rotation use case Video.">Use Case Video</a>
